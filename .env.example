# Database (required for Prisma)
# For Vercel: use pooled connection (Neon/Supabase pooler) for DATABASE_URL
# Run migrations locally with DIRECT_URL before deploying
DATABASE_URL="postgresql://username:password@localhost:5432/resqcity?schema=public"
DIRECT_URL="postgresql://username:password@localhost:5432/resqcity?schema=public"

# Supabase (for cloud storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Mapbox
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="your-mapbox-token-here"

# WebSocket
NEXT_PUBLIC_WEBSOCKET_URL="http://localhost:3000"
# Realtime mode: auto | polling
# Use polling on Vercel/free when no dedicated socket server is deployed.
NEXT_PUBLIC_REALTIME_MODE="auto"

# Weather (server-side preferred)
OPENWEATHER_API_KEY="your-openweather-key"
# Legacy fallback (avoid in production)
NEXT_PUBLIC_OPENWEATHER_KEY="your-openweather-key"

# KEP Digital Signature (Bulgarian eAuth)
KEP_API_URL="https://eauth.egov.bg/api"
KEP_CLIENT_ID="your-kep-client-id"
KEP_CLIENT_SECRET="your-kep-client-secret"

# Inbound email processing
# Shared secret used by /api/inbound-email and PHP bridge
INBOUND_EMAIL_AUTH_TOKEN="change-this-to-a-long-random-secret"
# Optional (PHP bridge): trim forwarded update note length
INBOUND_EMAIL_MAX_NOTE_CHARS="1200"

# BISS integration (local browser signing)
# BISS runs locally on HTTPS ports 53952-53955. Browser scans these ports.
# Universal mode (default): works without extra BISS env keys.
# Strict mode (optional): enables signedContents/signedContentsCert for /sign request.
BISS_PROTOCOL_VERSION="1.0"
# Strict mode only: PEM private key used to sign original content (signedContents).
# You can place PEM directly or base64-encoded PEM.
BISS_REQUEST_SIGNING_PRIVATE_KEY_PEM=""
# Strict mode only: Base64 (DER) of server certificate corresponding to private key above.
BISS_REQUEST_SIGNING_CERT_B64=""

# Email Configuration (Fallback)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-email-password"
SMTP_FROM="noreply@resqcity.bg"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# For Vercel: set to your production URL, e.g. https://your-app.vercel.app
# NEXT_PUBLIC_WEBSOCKET_URL - not used on Vercel (real-time uses API polling)
NODE_ENV="development"
